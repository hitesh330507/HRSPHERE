{
  "info": {
    "name": "HRSphere API Collection",
    "description": "Postman Collection for HRSphere HR Management microservices.\n\n### Prerequisites\n1. Ensure the stack is running via `docker compose up -d`.\n2. Ensure databases are provisioned via `./infra/postgres/apply-databases.sh`.\n\n### Usage Flow\n1. Select the `HRSphere Dev` environment.\n2. Execute **Auth Service / Login** using the default seeded admin account (`admin` / `Admin123!`). This will automatically populate the `{{access_token}}` and `{{refresh_token}}` environment variables.\n3. Run any other requests. The Bearer tokens will propagate automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"hr_manager_1\",\n  \"email\": \"hr_manager_1@hrsphere.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"ROLE_HR\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    const json = pm.response.json();",
                  "    pm.environment.set(\"access_token\", json.accessToken);",
                  "    pm.environment.set(\"refresh_token\", json.refreshToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        },
